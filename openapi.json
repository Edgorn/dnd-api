              "type": "string"
            },
            "description": "Array de IDs o nombres de sistemas asociados."
          },
          "name": {
            "type": "string",
            "description": "Nombre de la habilidad."
          },
          "description": {
            "type": "string",
            "description": "Descripción detallada."
          },
